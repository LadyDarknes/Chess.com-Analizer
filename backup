FILES = "abcdefgh"
RANKS = "12345678"

def mapper():
    mapping = {}
    reverse_mapping = {}
    for c_idx, char in enumerate(FILES):
        for r_idx, num in enumerate(RANKS):
            square_name = f"{char}{num}"
            class_name = f"square-{c_idx + 1}{r_idx + 1}"
            mapping[square_name] = class_name
            reverse_mapping[class_name] = square_name
    return mapping, reverse_mapping

SQUARE_TO_CLASS, CLASS_TO_SQUARE = mapper()

def inject():
    options = Options()
    options.add_experimental_option("debuggerAddress", "127.0.0.1:9222")
    return webdriver.Chrome(options=options)

def div_fenstripe(driver):
    board = [[None for _ in range(8)] for _ in range(8)]
    pieces = driver.find_elements(By.CSS_SELECTOR, "div.piece")
    
    print(f"Bulunan parça sayısı: {len(pieces)}")
    
    for piece in pieces:
        classes = piece.get_attribute("class")
        match = re.search(r'square-(\d)(\d)', classes)
        if not match: continue
            
        file_idx = int(match.group(1)) - 1
        rank_idx = int(match.group(2)) - 1
        
        type_match = re.search(r'\b([wb])([pnbrqk])\b', classes)
        if type_match:
            color = type_match.group(1)
            role = type_match.group(2)
            fen_char = role.upper() if color == 'w' else role.lower()
            board[rank_idx][file_idx] = fen_char

    fen_rows = []
    has_white_king = False
    has_black_king = False
    
    for r in range(7, -1, -1):
        empty_count = 0
        row_str = ""
        for c in range(8):
            piece = board[r][c]
            if piece:
                if piece == 'K': has_white_king = True
                if piece == 'k': has_black_king = True
                
                if empty_count > 0:
                    row_str += str(empty_count)
                    empty_count = 0
                row_str += piece
            else:
                empty_count += 1
        if empty_count > 0:
            row_str += str(empty_count)
        fen_rows.append(row_str)
        
    final_fen = "/".join(fen_rows)
    
    # Validasyon: Krallar yoksa FEN hatalıdır
    if not has_white_king or not has_black_king:
        print("FEN Hatası: Krallar eksik! (Animasyon?)")
        return None
        
    return final_fen

def selElo(driver):
    try:
        selectors = [
            "[data-cy='user-tagline-rating']",
            ".cc-user-rating-white", 
            ".user-tagline-rating",
            ".user-rating"
        ]
        
        found_elements = []
        for s in selectors:
            for el in driver.find_elements(By.CSS_SELECTOR, s):
                text = el.text.strip()
                if text:
                    found_elements.append({'y': el.location['y'], 'text': text})
        
        if not found_elements: return 1500
        
        found_elements.sort(key=lambda x: x['y'])
        elo_text = found_elements[0]['text']
        
        nums = re.findall(r'\d+', elo_text)
        if nums:
            val = int(nums[0])
            if val > 100: return val
        return 1500
    except:
        return 1500

def SelMaia(elo):
    models = [1100, 1200, 1300, 1400, 1500, 1600, 1700, 1800, 1900]
    opp_model = min(models, key=lambda x: abs(x - elo))
    maia_file = f"maia/maia-{opp_model}.pb.gz"
    print(f"elo: {elo}")
    return maia_file

def GetBestMove(fen, turn_color, maia_file):
    if not fen: return []
    full_fen = f"{fen} {turn_color} - - 0 1"
    print(f"Analiz FEN: {full_fen}")
    
    try:
        cmd = ["lc0.exe", f"--weights={maia_file}"]
        engine = subprocess.Popen(
            cmd,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
            bufsize=1
        )
        
        engine.stdin.write("uci\n")
        engine.stdin.write("ucinewgame\n")
        engine.stdin.write(f"position fen {full_fen}\n")
        engine.stdin.write("setoption name MultiPV value 3\n")
        engine.stdin.write("go nodes 100\n") 
        engine.stdin.flush()
        
        moves = []
        while True:
            line = engine.stdout.readline()
            if not line: break
            line = line.strip()
            
            if line.startswith("bestmove"):
                parts = line.split()
                if len(parts) > 1 and parts[1] not in moves:
                    moves.insert(0, parts[1])
                break
            
            if line.startswith("info") and "pv" in line:
                try:
                    parts = line.split()
                    pv_index = parts.index("pv")
                    move = parts[pv_index + 1]
                    if move not in moves:
                        moves.append(move)
                except: pass
        
        engine.terminate()
        return moves[:3]
        
    except Exception as e:
        print(f"GetBestMove(): {e}")
        return []

def visualApply(driver, moves, is_black):
    if not moves: return

    colors = ["#f44336", "#ff9800", "#ffeb3b"]
    visual_data = []
    
    for idx, move in enumerate(moves):
        if idx >= 3: break
        
        from_sq = move[:2] 
        to_sq = move[2:4] 
        f_from = FILES.index(from_sq[0])
        r_from = RANKS.index(from_sq[1])
        f_to = FILES.index(to_sq[0])
        r_to = RANKS.index(to_sq[1])
        
        visual_data.append({
            "from": {"f": f_from, "r": r_from},
            "to": {"f": f_to, "r": r_to},
            "color": colors[idx],
            "opacity": 0.9 if idx == 0 else 0.6
        })

    data_json = json.dumps(visual_data)
    flipped_js_bool = "true" if is_black else "false"

    script = f"""
    (function() {{
        const board = document.querySelector('chess-board') || document.querySelector('#board-layout-chessboard') || document.querySelector('.board') || document.querySelector('wc-chess-board');
        const anyPiece = document.querySelector('.piece');
        const targetBoard = board || (anyPiece ? anyPiece.parentElement : document.body);

        const rect = targetBoard.getBoundingClientRect();
        
        let overlay = document.getElementById('rc-overlay');
        if (overlay) overlay.remove(); 
        
        overlay = document.createElement('div');
        overlay.id = 'rc-overlay';
        overlay.style.position = 'absolute';
        overlay.style.top = (rect.top + window.scrollY) + 'px';
        overlay.style.left = (rect.left + window.scrollX) + 'px';
        overlay.style.width = rect.width + 'px';
        overlay.style.height = rect.height + 'px';
        overlay.style.pointerEvents = 'none';
        overlay.style.zIndex = '9999';
        document.body.appendChild(overlay);
        
        const isFlipped = {flipped_js_bool};
        
        function getCenter(f, r) {{
            let x, y;
            if (isFlipped) {{
                x = (7 - f) * 12.5;
                y = r * 12.5; 
            }} else {{
                x = f * 12.5;
                y = (7 - r) * 12.5;
            }}
            return {{ x: x + 6.25, y: y + 6.25 }};
        }}

        const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
        svg.style.width = '100%';
        svg.style.height = '100%';
        svg.setAttribute("viewBox", "0 0 100 100"); 
        
        const moves = {data_json};

        moves.forEach(m => {{
            const start = getCenter(m.from.f, m.from.r);
            const end = getCenter(m.to.f, m.to.r);
            
            const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
            line.setAttribute("x1", start.x); line.setAttribute("y1", start.y);
            line.setAttribute("x2", end.x); line.setAttribute("y2", end.y);
            line.setAttribute("stroke", m.color);
            line.setAttribute("stroke-width", "0.6");
            line.style.opacity = "0.5";
            svg.appendChild(line);

            const c = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            c.setAttribute("cx", end.x); c.setAttribute("cy", end.y);
            c.setAttribute("r", "3.5");
            c.setAttribute("fill", "none");
            c.setAttribute("stroke", m.color);
            c.setAttribute("stroke-width", "1");
            c.style.opacity = m.opacity;
            svg.appendChild(c);
        }});
        overlay.appendChild(svg);
    }})();
    """
    driver.execute_script(script)

def find_side(driver):
    try:
        # Önce standart class kontrolü
        script_class = """
            const board = document.querySelector('chess-board') || document.querySelector('#board-layout-chessboard') || document.querySelector('wc-chess-board');
            if (board && board.classList.contains('flipped')) return true;
            return false;
        """
        is_flipped_class = driver.execute_script(script_class)
        if is_flipped_class:
            return 'b'

        script_coords = """
            const coords = Array.from(document.querySelectorAll('.coordinate-light, .coordinate-dark, .coords-light, .coords-dark, text.coordinate'));
            const one = coords.find(c => c.innerHTML.trim() === '1' || c.textContent.trim() === '1');
            
            if (!one) return 'unknown';
            
            const rect = one.getBoundingClientRect();
            const centerY = window.innerHeight / 2;
            return rect.top > centerY ? 'bottom' : 'top';
        """
        pos = driver.execute_script(script_coords)
        
        if pos == 'top': return 'b'
        if pos == 'bottom': return 'w'
        
        return 'w' # Varsayılan
    except: return 'w'

def checkc(driver, me_color):
    try:
        script = """
        (function() {
            const highlights = document.querySelectorAll('.highlight');
            if (highlights.length === 0) return 'start';

            for (let sq of highlights) {
                const classes = sq.className;
                const match = classes.match(/square-(\\d+)/);
                if (!match) continue;
                
                const sqClass = match[0];
                const piece = document.querySelector(`.piece.${sqClass}`);
                
                if (piece) {
                    if (piece.classList.contains('w') || piece.className.includes('w')) return 'w';
                    if (piece.classList.contains('b') || piece.className.includes('b')) return 'b';
                    
                    const pClasses = piece.className;
                    if (pClasses.includes('wp') || pClasses.includes('wn') || pClasses.includes('wb') || pClasses.includes('wr') || pClasses.includes('wq') || pClasses.includes('wk')) return 'w';
                    return 'b';
                }
            }
            return 'unknown';
        })();
        """
        who_am_I = driver.execute_script(script)
        
        if who_am_I == 'start':
            return True if me_color == 'w' else False
        
        if who_am_I == 'unknown':
            return False
            
        return who_am_I != me_color
        
    except Exception as e:
        print(f"checkc(): {e}")
        return False

def main():
    try:
        driver = inject()
        print("Injected!")
        time.sleep(1)
        
        me_color = find_side(driver)
      # print(f"{'Siyah' if me_color == 'b' else 'Beyaz'}")
        
        elo = selElo(driver)
        maia_file = SelMaia(elo)
        
        last_fen = "start"
        
        while True:
            try:
                is_my_turn = checkc(driver, me_color)
                
                if is_my_turn:
                    time.sleep(0.3) 
                    current_fen = div_fenstripe(driver)
                    
                    if current_fen and current_fen != last_fen:
                        print("Hesaplanıyor...")
                        best_moves = GetBestMove(current_fen, me_color, maia_file)
                        
                        if best_moves:
                            print(f"Öneri: {best_moves}")
                            visualApply(driver, best_moves, me_color == 'b')
                            last_fen = current_fen
                        else:
                            print("Hamle bulunamadı.")
                    elif current_fen is None:
                        time.sleep(0.5)
                    else:
                        time.sleep(0.5)
                else:
                    driver.execute_script("const o=document.getElementById('rc-overlay'); if(o) o.remove();")
                    time.sleep(0.5)
                    
            except Exception as e:
                print(f"Loop: {e}")
                time.sleep(1)
                
    except Exception as e:
        print(f"main() : {e}")

if __name__ == "__main__":
    main()